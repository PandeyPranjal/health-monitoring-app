# ── Django Health App Environment ─────────────────────
# Copy this file to .env and fill in your values.
# The .env file is git-ignored and will NOT be committed.

# Django
SECRET_KEY=change-this-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Fitbit OAuth2 (optional — app works without it)
# Register at https://dev.fitbit.com/apps/new
# Set callback URL to: http://localhost:8000/api/health/fitbit/callback/
FITBIT_CLIENT_ID=your_fitbit_client_id_here
FITBIT_CLIENT_SECRET=your_fitbit_client_secret_here
FITBIT_REDIRECT_URI=http://localhost:8000/api/health/fitbit/callback/
